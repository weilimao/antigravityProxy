{
  "name": "antigravity-proxy-desktop",
  "version": "1.0.3",
  "description": "Antigravity Proxy Desktop Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "publish": "node scripts/publish.js"
  },
  "author": "weilimao",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weilimao/antigravityProxy.git"
  },
  "build": {
    "appId": "com.weilimao.antigravityproxy",
    "productName": "Antigravity Proxy",
    "artifactName": "antigravity-proxy-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "engine.js",
      "index.html",
      "src/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "weilimao",
        "repo": "antigravityProxy"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "asar": "^3.2.0",
    "http-mitm-proxy": "^1.1.0"
  }
}
